# Gemini API
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL=gemini-1.5-flash

# GROQ API
GROQ_API_KEY_1="your_groq_api_key_1_here"
GROQ_API_KEY_2="your_groq_api_key_2_here"
GROQ_API_KEY_3="your_groq_api_key_3_here"

# NVIDIA NIM API
NIM_MODEL="mistralai/mistral-large-2407"
NVIDIA_API_KEY="your_nvidia_api_key_here"

# OpenRouter API
OPENROUTER_API_KEY="your_openrouter_api_key_here"
OPENROUTER_MODEL="nvidia/nemotron-3-super-120b-a12b:free"
OPENROUTER_FALLBACK_MODELS="google/gemma-2-9b-it:free,meta-llama/llama-3.1-8b-instruct:free,mistralai/mistral-7b-instruct:free"

# LinkedIn Credentials
LINKEDIN_EMAIL="your_linkedin_email"
LINKEDIN_PASSWORD="your_linkedin_password"

# Ollama (optional, for local fallback)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Instahyre Credentials
INSTAHYRE_EMAIL="your_instahyre_email"
INSTAHYRE_PASSWORD="your_instahyre_password"

# Twitter/X Credentials
TWITTER_EMAIL="your_twitter_username"
TWITTER_PASSWORD="your_twitter_password"

# ChatGPT Credentials
CHATGPT_EMAIL="your_chatgpt_email"
CHATGPT_PASSWORD="your_chatgpt_password"

# Claude Subprocess Scoring (via claude -p CLI)
CLAUDE_BATCH_SIZE=25
CLAUDE_MODEL=claude-sonnet-4-6
